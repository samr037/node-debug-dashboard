#!/bin/bash
# ndiag-disk — Disk diagnostics for Node Debug Dashboard
# Usage: ndiag-disk [subcommand]
# Subcommands: health, io, usage, bench, all

set -euo pipefail

C_RESET="\033[0m"
C_BOLD="\033[1m"
C_CYAN="\033[36m"
C_GREEN="\033[32m"
C_YELLOW="\033[33m"
C_RED="\033[31m"
C_DIM="\033[2m"

header() { echo -e "\n${C_BOLD}${C_CYAN}── $1 ──${C_RESET}\n"; }

cmd_health() {
    header "SMART Health Summary"
    # Only real disks with non-zero size, skip virtual/loop
    local disks=$(lsblk -dno NAME,TYPE,SIZE 2>/dev/null | awk '$2=="disk" && $3!="0B" && $3!="0"{print $1}')

    if [ -z "$disks" ]; then
        echo -e "  ${C_DIM}No disks found${C_RESET}"
        return
    fi

    for disk in $disks; do
        local dev="/dev/${disk}"
        local model=$(lsblk -dno MODEL "/dev/${disk}" 2>/dev/null | xargs)
        local size=$(lsblk -dno SIZE "/dev/${disk}" 2>/dev/null)

        # Skip virtual disks (Longhorn, CSI) — no model or "VIRTUAL"
        [[ -z "$model" || "$model" == *VIRTUAL* || "$model" == *"Storage Device"* ]] && continue

        # Try default smartctl, fall back to -d sat for USB bridges
        local smart=$(smartctl -H "$dev" 2>/dev/null)
        local health=$(echo "$smart" | grep -iE "SMART overall|SMART Health" | awk -F: '{print $2}' | xargs)
        if [ -z "$health" ]; then
            smart=$(smartctl -H -d sat "$dev" 2>/dev/null)
            health=$(echo "$smart" | grep -iE "SMART overall|SMART Health" | awk -F: '{print $2}' | xargs)
        fi

        local color="$C_GREEN"
        local icon="✓"
        if [ -z "$health" ]; then
            color="$C_DIM"; icon="?"; health="N/A"
        elif [[ "$health" != *"PASSED"* ]] && [[ "$health" != *"OK"* ]]; then
            color="$C_RED"; icon="✗"
        fi

        printf "  ${color}${icon}${C_RESET} %-8s %-30s %6s  ${color}%s${C_RESET}\n" "$disk" "$model" "$size" "$health"

        # Key SMART attributes — try both default and -d sat
        local output=$(smartctl -A "$dev" 2>/dev/null)
        [ -z "$output" ] && output=$(smartctl -A -d sat "$dev" 2>/dev/null)
        if [ -n "$output" ]; then
            echo "$output" | grep -iE "Reallocated|Pending|Uncorrectable|Wear_Leveling|Power_On_Hours|Temperature" | \
                awk '{
                    val=$10; name=$2
                    if (name ~ /Reallocated/ && val+0 > 0) color="\033[31m"
                    else if (name ~ /Pending/ && val+0 > 0) color="\033[33m"
                    else color="\033[2m"
                    printf "    %s%-30s %s\033[0m\n", color, name, val
                }'
        fi
        echo ""
    done
}

cmd_io() {
    header "I/O Statistics"

    # Current I/O from /proc/diskstats (skip loop devices)
    echo -e "${C_DIM}  DISK       READ/s    WRITE/s    READ KB/s  WRITE KB/s${C_RESET}"
    local disks=$(lsblk -dno NAME,TYPE 2>/dev/null | awk '$2=="disk"{print $1}')
    for disk in $disks; do
        local stats1=$(awk -v d="$disk" '$3==d {print $4, $6, $8}' "${HOST_PROC:-/host-proc}/diskstats" 2>/dev/null)
        [ -z "$stats1" ] && continue
        sleep 1
        local stats2=$(awk -v d="$disk" '$3==d {print $4, $6, $8}' "${HOST_PROC:-/host-proc}/diskstats" 2>/dev/null)

        local r1=$(echo "$stats1" | awk '{print $1}')
        local w1=$(echo "$stats1" | awk '{print $2}')
        local rs1=$(echo "$stats1" | awk '{print $3}')
        local r2=$(echo "$stats2" | awk '{print $1}')
        local w2=$(echo "$stats2" | awk '{print $2}')
        local rs2=$(echo "$stats2" | awk '{print $3}')

        local rd=$((r2 - r1))
        local wd=$((w2 - w1))
        printf "  %-10s %6d    %7d\n" "$disk" "$rd" "$wd"
    done

    # iostat if available
    echo ""
    header "iostat Snapshot"
    iostat -xd 1 2 2>/dev/null | tail -n +4 | grep -vE '^$|^loop' | head -20 | sed 's/^/  /' || \
        echo -e "  ${C_DIM}iostat not available${C_RESET}"
}

cmd_usage() {
    header "Disk Space Usage"
    echo -e "${C_DIM}  FILESYSTEM                    SIZE   USED  AVAIL  USE%  MOUNT${C_RESET}"
    df -h 2>/dev/null | grep -vE 'tmpfs|overlay|shm|Filesystem|^none|^rootfs' | sort -k5 -rn | \
    while read -r fs size used avail pct mount; do
        local num=${pct%\%}
        local color="$C_GREEN"
        [ "$num" -gt 70 ] 2>/dev/null && color="$C_YELLOW"
        [ "$num" -gt 90 ] 2>/dev/null && color="$C_RED"
        printf "  %-30s %5s  %5s  %5s  ${color}%4s${C_RESET}  %s\n" "$fs" "$size" "$used" "$avail" "$pct" "$mount"
    done

    echo ""
    header "Inode Usage (non-trivial)"
    df -ih 2>/dev/null | grep -vE 'tmpfs|overlay|shm|Filesystem|^none|^rootfs' | awk '$5+0 > 10 {
        printf "  %-30s %5s  %5s  %5s  %4s  %s\n", $1, $2, $3, $4, $5, $6
    }'
}

cmd_bench() {
    header "Quick Sequential I/O Benchmark"
    echo -e "${C_YELLOW}  Writing 256MB test file...${C_RESET}"
    local tmpfile="/tmp/ndiag-bench-$$"

    # Write test
    local write_result=$(dd if=/dev/zero of="$tmpfile" bs=1M count=256 conv=fdatasync 2>&1)
    local write_speed=$(echo "$write_result" | grep -oP '[\d.]+ [MGKT]B/s' | tail -1)
    echo -e "  Write: ${C_BOLD}${write_speed:-N/A}${C_RESET}"

    # Flush cache
    sync
    echo 3 > /proc/sys/vm/drop_caches 2>/dev/null || true

    # Read test
    local read_result=$(dd if="$tmpfile" of=/dev/null bs=1M count=256 2>&1)
    local read_speed=$(echo "$read_result" | grep -oP '[\d.]+ [MGKT]B/s' | tail -1)
    echo -e "  Read:  ${C_BOLD}${read_speed:-N/A}${C_RESET}"

    rm -f "$tmpfile"
    echo ""
    echo -e "${C_DIM}  For thorough benchmarks: fio --name=test --bs=4k --rw=randread --size=128M --runtime=10${C_RESET}"
}

cmd_all() {
    cmd_health
    cmd_usage
    cmd_io
}

show_help() {
    cat << 'EOF'
ndiag-disk — Disk diagnostics for Kubernetes nodes

USAGE
    ndiag-disk <subcommand>

SUBCOMMANDS
    health     SMART health + key attributes for all disks
    io         Live I/O statistics (1s sample + iostat)
    usage      Disk space and inode usage
    bench      Quick 256MB sequential read/write benchmark
    all        Run health + usage + io

EXAMPLES
    ndiag-disk health       # Quick SMART check
    ndiag-disk usage        # Disk space overview
    ndiag-disk bench        # Sequential I/O speed
    ndiag-disk all | less   # Full report

NOTES
    - SMART requires smartctl and direct disk access (privileged)
    - bench writes a 256MB temp file to /tmp — safe on most setups
    - For NVMe: nvme smart-log /dev/nvme0n1
    - For fio benchmarks: fio --name=test --bs=4k --rw=randread --size=128M
EOF
}

case "${1:-all}" in
    health)  cmd_health ;;
    io)      cmd_io ;;
    usage)   cmd_usage ;;
    bench)   cmd_bench ;;
    all)     cmd_all ;;
    -h|--help|help) show_help ;;
    *) echo "Unknown subcommand: $1"; echo "Run 'ndiag-disk --help' for usage"; exit 1 ;;
esac
