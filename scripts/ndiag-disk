#!/bin/bash
# ndiag-disk — Disk diagnostics for Node Debug Dashboard
# Usage: ndiag-disk [subcommand]
# Subcommands: health, io, usage, bench, all

set -euo pipefail

C_RESET="\033[0m"
C_BOLD="\033[1m"
C_CYAN="\033[36m"
C_GREEN="\033[32m"
C_YELLOW="\033[33m"
C_RED="\033[31m"
C_DIM="\033[2m"

header() { echo -e "\n${C_BOLD}${C_CYAN}── $1 ──${C_RESET}\n"; }

_smart_attr() {
    # Print a SMART attribute with color coding
    # Usage: _smart_attr "Label" "value" "unit" "warn_threshold" "crit_threshold" "invert"
    local label="$1" val="$2" unit="${3:-}" warn="${4:-}" crit="${5:-}" invert="${6:-}"
    [ -z "$val" ] || [ "$val" = "0" ] && return
    local color="$C_DIM"
    if [ -n "$crit" ] && [ "$val" -gt "$crit" ] 2>/dev/null; then
        color="$C_RED"
    elif [ -n "$warn" ] && [ "$val" -gt "$warn" ] 2>/dev/null; then
        color="$C_YELLOW"
    fi
    # Invert: lower is worse (e.g., Available_Spare)
    if [ "$invert" = "1" ] && [ -n "$warn" ]; then
        color="$C_DIM"
        [ "$val" -lt "$warn" ] 2>/dev/null && color="$C_YELLOW"
        [ -n "$crit" ] && [ "$val" -lt "$crit" ] 2>/dev/null && color="$C_RED"
    fi
    printf "    ${color}%-28s %s%s${C_RESET}\n" "$label" "$val" "$unit"
}

_parse_ata_smart() {
    local dev="$1" dtype="$2"
    local args=""
    [ -n "$dtype" ] && args="-d $dtype"
    local output
    output=$(eval smartctl -A $args "$dev" 2>/dev/null) || true
    [ -z "$output" ] && return 1

    # Extract raw values by attribute name
    _ata_raw() { echo "$output" | awk -v name="$1" '$2==name{print $10}' | head -1; }

    local hours=$(_ata_raw Power_On_Hours)
    local cycles=$(_ata_raw Power_Cycle_Count)
    local temp=$(_ata_raw Temperature_Celsius)
    # Clean temp (may have Min/Max suffix)
    temp=${temp%% *}

    local realloc=$(_ata_raw Reallocated_Sector_Ct)
    [ -z "$realloc" ] && realloc=$(_ata_raw Reallocate_NAND_Blk_Cnt)
    local realloc_ev=$(_ata_raw Reallocated_Event_Count)
    local pending=$(_ata_raw Current_Pending_Sector)
    [ -z "$pending" ] && pending=$(_ata_raw Current_Pending_ECC_Cnt)
    local uncorrect=$(_ata_raw Offline_Uncorrectable)
    local udma_err=$(_ata_raw UDMA_CRC_Error_Count)

    # SSD-specific
    local wear=$(_ata_raw Wear_Leveling_Count)
    local lifetime=$(_ata_raw Percent_Lifetime_Remain)
    local avg_erase=$(_ata_raw Ave_Block-Erase_Count)
    [ -z "$avg_erase" ] && avg_erase=$(_ata_raw Average_PE_Cycles_TLC)
    [ -z "$avg_erase" ] && avg_erase=$(_ata_raw Block_Erase_Count)
    local host_writes=$(_ata_raw Host_Writes_GiB)
    [ -z "$host_writes" ] && host_writes=$(_ata_raw Total_LBAs_Written)
    local host_reads=$(_ata_raw Host_Reads_GiB)
    local nand_writes=$(_ata_raw NAND_GB_Written_TLC)
    local prog_fail=$(_ata_raw Program_Fail_Count)
    local erase_fail=$(_ata_raw Erase_Fail_Count)
    local reserve=$(_ata_raw Available_Reservd_Space)
    [ -z "$reserve" ] && reserve=$(_ata_raw Unused_Reserve_NAND_Blk)
    local unexp_power=$(_ata_raw Unexpected_Power_Loss)
    [ -z "$unexp_power" ] && unexp_power=$(_ata_raw Unexpect_Power_Loss_Ct)

    # HDD-specific
    local spin_up=$(_ata_raw Spin_Up_Time)
    local seek_err=$(_ata_raw Seek_Error_Rate)
    local load_cycle=$(_ata_raw Load_Cycle_Count)
    local read_err=$(_ata_raw Raw_Read_Error_Rate)

    # Always show
    _smart_attr "Power-On Hours" "$hours" "h"
    _smart_attr "Power Cycles" "$cycles" ""
    _smart_attr "Temperature" "$temp" "°C" "55" "70"

    # Reliability (critical first)
    _smart_attr "Reallocated Sectors" "$realloc" "" "0" "10"
    _smart_attr "Reallocated Events" "$realloc_ev" "" "0" "5"
    _smart_attr "Pending Sectors" "$pending" "" "0" "1"
    _smart_attr "Uncorrectable" "$uncorrect" "" "0" "1"
    _smart_attr "UDMA CRC Errors" "$udma_err" "" "100" "1000"

    # SSD wear
    _smart_attr "Lifetime Remaining" "$lifetime" "%" "20" "5" "1"
    _smart_attr "Avg Erase Cycles" "$avg_erase" ""
    _smart_attr "Host Writes" "$host_writes" " GiB"
    _smart_attr "Host Reads" "$host_reads" " GiB"
    _smart_attr "NAND Writes" "$nand_writes" " GiB"
    _smart_attr "Program Fail" "$prog_fail" "" "0" "1"
    _smart_attr "Erase Fail" "$erase_fail" "" "0" "1"
    _smart_attr "Reserved Space" "$reserve" "%"
    _smart_attr "Unexpected Power Loss" "$unexp_power" ""

    # HDD mechanical
    _smart_attr "Spin-Up Time" "$spin_up" "ms"
    _smart_attr "Load Cycles" "$load_cycle" ""

    return 0
}

_parse_nvme_smart() {
    local dev="$1"
    local output
    output=$(smartctl -A "$dev" 2>/dev/null) || true
    [ -z "$output" ] && return 1

    # NVMe uses "Key:  Value" format
    _nvme_val() { echo "$output" | grep -i "^$1" | head -1 | awk -F: '{gsub(/^[ \t]+|[ \t]+$/,"",$2); print $2}'; }

    local temp=$(_nvme_val "Temperature:")
    temp=${temp%% *}  # strip " Celsius"
    local spare=$(_nvme_val "Available Spare:")
    spare=${spare%%%}  # strip %
    local spare_thresh=$(_nvme_val "Available Spare Threshold:")
    spare_thresh=${spare_thresh%%%}
    local pct_used=$(_nvme_val "Percentage Used:")
    pct_used=${pct_used%%%}
    local data_read=$(_nvme_val "Data Units Read:")
    local data_written=$(_nvme_val "Data Units Written:")
    local hours=$(_nvme_val "Power On Hours:")
    hours=$(echo "$hours" | tr -d ',')
    local cycles=$(_nvme_val "Power Cycles:")
    cycles=$(echo "$cycles" | tr -d ',')
    local unsafe=$(_nvme_val "Unsafe Shutdowns:")
    unsafe=$(echo "$unsafe" | tr -d ',')
    local integrity=$(_nvme_val "Media and Data Integrity Errors:")
    integrity=$(echo "$integrity" | tr -d ',')
    local errors=$(_nvme_val "Error Information Log Entries:")
    errors=$(echo "$errors" | tr -d ',')
    local warn_temp=$(_nvme_val "Warning.*Comp.*Temp.*Time:")
    local crit_temp=$(_nvme_val "Critical.*Comp.*Temp.*Time:")

    _smart_attr "Power-On Hours" "$hours" "h"
    _smart_attr "Power Cycles" "$cycles" ""
    _smart_attr "Temperature" "$temp" "°C" "60" "75"
    _smart_attr "Available Spare" "$spare" "%" "20" "10" "1"
    _smart_attr "Spare Threshold" "$spare_thresh" "%"
    _smart_attr "Percentage Used" "$pct_used" "%" "80" "95"
    _smart_attr "Data Written" "$data_written" ""
    _smart_attr "Data Read" "$data_read" ""
    _smart_attr "Unsafe Shutdowns" "$unsafe" "" "50" "200"
    _smart_attr "Integrity Errors" "$integrity" "" "0" "1"
    _smart_attr "Error Log Entries" "$errors" ""
    _smart_attr "Warning Temp Time" "$warn_temp" "" "0" "1"
    _smart_attr "Critical Temp Time" "$crit_temp" "" "0" "1"

    return 0
}

cmd_health() {
    header "SMART Health Summary"
    # Only real disks with non-zero size, skip virtual/loop
    local disks=$(lsblk -dno NAME,TYPE,SIZE 2>/dev/null | awk '$2=="disk" && $3!="0B" && $3!="0"{print $1}')

    if [ -z "$disks" ]; then
        echo -e "  ${C_DIM}No disks found${C_RESET}"
        return
    fi

    for disk in $disks; do
        local dev="/dev/${disk}"
        local model=$(lsblk -dno MODEL "/dev/${disk}" 2>/dev/null | xargs)
        local size=$(lsblk -dno SIZE "/dev/${disk}" 2>/dev/null)

        # Skip virtual disks (Longhorn, CSI) — no model or "VIRTUAL"
        [[ -z "$model" || "$model" == *VIRTUAL* || "$model" == *"Storage Device"* ]] && continue

        # Detect disk type
        local is_nvme=0
        [[ "$disk" == nvme* ]] && is_nvme=1

        # Get health status — try default, then -d sat for USB bridges
        local dtype=""
        local smart=$(smartctl -H "$dev" 2>/dev/null) || true
        local health=$(echo "$smart" | grep -iE "SMART overall|SMART Health" | awk -F: '{print $2}' | xargs) || true
        if [ -z "$health" ] && [ "$is_nvme" = "0" ]; then
            dtype="sat"
            smart=$(smartctl -H -d sat "$dev" 2>/dev/null) || true
            health=$(echo "$smart" | grep -iE "SMART overall|SMART Health" | awk -F: '{print $2}' | xargs) || true
        fi

        local color="$C_GREEN"
        local icon="✓"
        if [ -z "$health" ]; then
            color="$C_DIM"; icon="?"; health="N/A"
        elif [[ "$health" != *"PASSED"* ]] && [[ "$health" != *"OK"* ]]; then
            color="$C_RED"; icon="✗"
        fi

        local disk_type="HDD"
        local rota=$(lsblk -dno ROTA "/dev/${disk}" 2>/dev/null)
        [ "$rota" = "0" ] && disk_type="SSD"
        [ "$is_nvme" = "1" ] && disk_type="NVMe"

        printf "  ${color}${icon}${C_RESET} ${C_BOLD}%-8s${C_RESET} %-30s %6s  ${color}%s${C_RESET}  ${C_DIM}[%s]${C_RESET}\n" \
            "$disk" "$model" "$size" "$health" "$disk_type"

        # Parse and display attributes
        if [ "$is_nvme" = "1" ]; then
            _parse_nvme_smart "$dev"
        else
            _parse_ata_smart "$dev" "$dtype"
        fi
        echo ""
    done
}

cmd_io() {
    header "I/O Statistics"

    # Current I/O from /proc/diskstats (skip loop devices)
    echo -e "${C_DIM}  DISK       READ/s    WRITE/s    READ KB/s  WRITE KB/s${C_RESET}"
    local disks=$(lsblk -dno NAME,TYPE 2>/dev/null | awk '$2=="disk"{print $1}')
    for disk in $disks; do
        local stats1=$(awk -v d="$disk" '$3==d {print $4, $6, $8}' "${HOST_PROC:-/host-proc}/diskstats" 2>/dev/null)
        [ -z "$stats1" ] && continue
        sleep 1
        local stats2=$(awk -v d="$disk" '$3==d {print $4, $6, $8}' "${HOST_PROC:-/host-proc}/diskstats" 2>/dev/null)

        local r1=$(echo "$stats1" | awk '{print $1}')
        local w1=$(echo "$stats1" | awk '{print $2}')
        local rs1=$(echo "$stats1" | awk '{print $3}')
        local r2=$(echo "$stats2" | awk '{print $1}')
        local w2=$(echo "$stats2" | awk '{print $2}')
        local rs2=$(echo "$stats2" | awk '{print $3}')

        local rd=$((r2 - r1))
        local wd=$((w2 - w1))
        printf "  %-10s %6d    %7d\n" "$disk" "$rd" "$wd"
    done

    # iostat if available
    echo ""
    header "iostat Snapshot"
    iostat -xd 1 2 2>/dev/null | tail -n +4 | grep -vE '^$|^loop' | head -20 | sed 's/^/  /' || \
        echo -e "  ${C_DIM}iostat not available${C_RESET}"
}

cmd_usage() {
    header "Disk Space Usage"
    echo -e "${C_DIM}  FILESYSTEM                    SIZE   USED  AVAIL  USE%  MOUNT${C_RESET}"
    df -h 2>/dev/null | grep -vE 'tmpfs|overlay|shm|Filesystem|^none|^rootfs' | sort -k5 -rn | \
    while read -r fs size used avail pct mount; do
        local num=${pct%\%}
        local color="$C_GREEN"
        [ "$num" -gt 70 ] 2>/dev/null && color="$C_YELLOW"
        [ "$num" -gt 90 ] 2>/dev/null && color="$C_RED"
        printf "  %-30s %5s  %5s  %5s  ${color}%4s${C_RESET}  %s\n" "$fs" "$size" "$used" "$avail" "$pct" "$mount"
    done

    echo ""
    header "Inode Usage (non-trivial)"
    df -ih 2>/dev/null | grep -vE 'tmpfs|overlay|shm|Filesystem|^none|^rootfs' | awk '$5+0 > 10 {
        printf "  %-30s %5s  %5s  %5s  %4s  %s\n", $1, $2, $3, $4, $5, $6
    }'
}

cmd_bench() {
    header "Quick Sequential I/O Benchmark"
    echo -e "${C_YELLOW}  Writing 256MB test file...${C_RESET}"
    local tmpfile="/tmp/ndiag-bench-$$"

    # Write test
    local write_result=$(dd if=/dev/zero of="$tmpfile" bs=1M count=256 conv=fdatasync 2>&1)
    local write_speed=$(echo "$write_result" | grep -oP '[\d.]+ [MGKT]B/s' | tail -1)
    echo -e "  Write: ${C_BOLD}${write_speed:-N/A}${C_RESET}"

    # Flush cache
    sync
    echo 3 > /proc/sys/vm/drop_caches 2>/dev/null || true

    # Read test
    local read_result=$(dd if="$tmpfile" of=/dev/null bs=1M count=256 2>&1)
    local read_speed=$(echo "$read_result" | grep -oP '[\d.]+ [MGKT]B/s' | tail -1)
    echo -e "  Read:  ${C_BOLD}${read_speed:-N/A}${C_RESET}"

    rm -f "$tmpfile"
    echo ""
    echo -e "${C_DIM}  For thorough benchmarks: fio --name=test --bs=4k --rw=randread --size=128M --runtime=10${C_RESET}"
}

cmd_all() {
    cmd_health
    cmd_usage
    cmd_io
}

show_help() {
    cat << 'EOF'
ndiag-disk — Disk diagnostics for Kubernetes nodes

USAGE
    ndiag-disk <subcommand>

SUBCOMMANDS
    health     SMART health + key attributes for all disks
    io         Live I/O statistics (1s sample + iostat)
    usage      Disk space and inode usage
    bench      Quick 256MB sequential read/write benchmark
    all        Run health + usage + io

EXAMPLES
    ndiag-disk health       # Quick SMART check
    ndiag-disk usage        # Disk space overview
    ndiag-disk bench        # Sequential I/O speed
    ndiag-disk all | less   # Full report

NOTES
    - SMART requires smartctl and direct disk access (privileged)
    - bench writes a 256MB temp file to /tmp — safe on most setups
    - For NVMe: nvme smart-log /dev/nvme0n1
    - For fio benchmarks: fio --name=test --bs=4k --rw=randread --size=128M
EOF
}

case "${1:-all}" in
    health)  cmd_health ;;
    io)      cmd_io ;;
    usage)   cmd_usage ;;
    bench)   cmd_bench ;;
    all)     cmd_all ;;
    -h|--help|help) show_help ;;
    *) echo "Unknown subcommand: $1"; echo "Run 'ndiag-disk --help' for usage"; exit 1 ;;
esac
