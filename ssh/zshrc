# Node Debug Dashboard — Zsh Configuration
# Loaded for both root and debug users

# === MOTD — show on interactive login shells only ===
if [[ -o login && -o interactive && -f /etc/profile.d/motd.sh ]]; then
    source /etc/profile.d/motd.sh
fi

# === Oh-My-Zsh ===
export ZSH="/opt/oh-my-zsh"
ZSH_THEME="agnoster"
ZSH_DISABLE_COMPFIX="true"
DISABLE_AUTO_UPDATE="true"
DISABLE_UPDATE_PROMPT="true"
plugins=(git docker kubectl colored-man-pages command-not-found zsh-autosuggestions zsh-syntax-highlighting)

# Add custom completions to fpath BEFORE oh-my-zsh runs compinit
[[ -d /opt/node-dashboard/ssh/completions ]] && fpath=(/opt/node-dashboard/ssh/completions $fpath)
[[ -d /usr/local/share/zsh/site-functions ]] && fpath=(/usr/local/share/zsh/site-functions $fpath)

source "$ZSH/oh-my-zsh.sh"

# === Prompt context — show user@node ===
prompt_context() {
    local node="${KUBERNETES_NODE_NAME:-$(hostname)}"
    prompt_segment black default "%(!.%{%F{yellow}%}.)%n@${node}"
}

# === Environment ===
export EDITOR=vim
export VISUAL=vim
export PAGER="less -R"
export LESS="-R -F -X"
export HOST_ROOT="${HOST_ROOT:-/host}"
export HOST_PROC="${HOST_PROC:-/host-proc}"
export CRICTL_RUNTIME_ENDPOINT="unix:///host/run/containerd/containerd.sock"
export PATH="/opt/node-dashboard/scripts:$PATH:/host/usr/local/bin:/host/usr/bin"

# === History ===
HISTSIZE=10000
SAVEHIST=10000
HISTFILE=~/.zsh_history
setopt HIST_IGNORE_DUPS
setopt HIST_IGNORE_SPACE
setopt SHARE_HISTORY
setopt APPEND_HISTORY
setopt INC_APPEND_HISTORY

# === Navigation ===
setopt AUTO_CD
setopt AUTO_PUSHD
setopt PUSHD_IGNORE_DUPS
setopt PUSHD_SILENT

# === Completion (oh-my-zsh already calls compinit) ===
zstyle ':completion:*' menu select
zstyle ':completion:*' matcher-list 'm:{a-zA-Z}={A-Za-z}'
zstyle ':completion:*:descriptions' format '%B%F{cyan}── %d ──%f%b'
zstyle ':completion:*:warnings' format '%F{red}No matches%f'

# ─── Host Namespace ───
alias hostns='nsenter --target 1 --mount --uts --ipc --net --pid -- /bin/bash'
alias hostsh='nsenter --target 1 --mount --uts --ipc --net --pid -- /bin/sh'
alias hostcmd='nsenter --target 1 --mount --uts --ipc --net --pid --'

# ─── Filesystem Navigation ───
alias hroot='cd /host'
alias hlog='cd /host/var/log'
alias hpods='cd /host/var/log/pods'
alias hetc='cd /host/etc'
alias hproc='cd /host-proc'
alias hkube='cd /host/etc/kubernetes'

# ─── Container Runtime ───
alias cps='crictl ps'
alias cpsa='crictl ps -a'
alias cpods='crictl pods'
alias cimg='crictl images'
alias clog='crictl logs'
alias clogf='crictl logs -f'
alias cinsp='crictl inspect'
alias cstats='crictl stats'
alias cexec='crictl exec -it'

# ─── Kubernetes (via curl + SA token) ───
_k8s_curl() {
    local path="$1"; shift
    command curl -sk --max-time 10 \
        --cacert /var/run/secrets/kubernetes.io/serviceaccount/ca.crt \
        -H "Authorization: Bearer $(cat /var/run/secrets/kubernetes.io/serviceaccount/token 2>/dev/null)" \
        "https://kubernetes.default.svc${path}" "$@"
}
alias kn='_k8s_curl /api/v1/nodes 2>/dev/null | jq -r ".items[] | \"\(.metadata.name)\t\(.status.conditions[-1].type)=\(.status.conditions[-1].status)\""'
alias kp='_k8s_curl /api/v1/pods 2>/dev/null | jq -r ".items[] | \"\(.metadata.namespace)\t\(.metadata.name)\t\(.status.phase)\""'
alias kpn='_k8s_curl "/api/v1/pods?fieldSelector=spec.nodeName=${KUBERNETES_NODE_NAME}" 2>/dev/null | jq -r ".items[] | \"\(.metadata.namespace)\t\(.metadata.name)\t\(.status.phase)\""'
alias kevents='_k8s_curl /api/v1/events 2>/dev/null | jq -r ".items | sort_by(.lastTimestamp) | .[-20:] | .[] | \"\(.lastTimestamp)\t\(.involvedObject.kind)/\(.involvedObject.name)\t\(.reason)\t\(.message[0:80])\""'

# ─── Networking ───
alias ports='ss -tlnp'
alias portsu='ss -ulnp'
alias conns='ss -tnp'
alias ifaces='ip -c -br addr'
alias routes='ip -c route'
alias listen='ss -tlnp | grep LISTEN'
alias pubip='curl -s ifconfig.me'
alias dnscheck='dig +short google.com @8.8.8.8'
alias pingg='ping -c3 8.8.8.8'
alias pingdns='ping -c3 google.com'
alias tcpd='tcpdump -i any -nn'
alias sniff='tcpdump -i any -nn -c 100'

# ─── Process & System ───
alias psmem='ps aux --sort=-%mem | head -20'
alias pscpu='ps aux --sort=-%cpu | head -20'
alias topmem='ps -eo pid,ppid,user,%mem,%cpu,rss,comm --sort=-%mem | head -20'
alias topcpu='ps -eo pid,ppid,user,%mem,%cpu,rss,comm --sort=-%cpu | head -20'
alias loadavg='cat /host-proc/loadavg'
alias memfree='free -h'
alias vmstats='vmstat 1 5'
alias iostats='iostat -x 1 5'

# ─── Disk & Storage ───
alias dfu='df -h | grep -v tmpfs | grep -v overlay'
alias dfi='df -ih | grep -v tmpfs | grep -v overlay'
alias lsblk='lsblk -o NAME,SIZE,TYPE,FSTYPE,MOUNTPOINT,MODEL'
alias smart='smartctl -a'
alias smartall='for d in $(lsblk -dno NAME | grep -E "^sd|^nvme"); do echo "=== $d ==="; smartctl -H /dev/$d 2>/dev/null; done'

# ─── Logs ===
alias dmesg='dmesg -T --color=always'
alias journalh='cat /host/var/log/journal/*/*.journal 2>/dev/null || echo "No journal files found"'
alias podlogs='ls /host/var/log/pods/'
podlog() {
    local pod_dir=$(ls -d /host/var/log/pods/*"$1"* 2>/dev/null | head -1)
    if [ -n "$pod_dir" ]; then
        local log=$(find "$pod_dir" -name "*.log" | sort | tail -1)
        [ -n "$log" ] && tail -f "$log" || echo "No log files found"
    else
        echo "No pod matching '$1' found in /host/var/log/pods/"
    fi
}

# ─── Hardware ───
alias cpuinfo='lscpu'
alias meminfo='dmidecode -t memory 2>/dev/null | grep -E "Size|Type|Speed|Locator" | head -30'
alias pcidev='lspci -v'
alias usbdev='lsusb -v 2>/dev/null | grep -E "^Bus|idVendor|idProduct|iProduct"'
alias sensors='cat /host/sys/class/thermal/thermal_zone*/temp 2>/dev/null | while read t; do echo "$((t/1000))°C"; done'
alias gpuinfo='nsenter --target 1 --mount --uts --ipc --net --pid -- nvidia-smi 2>/dev/null || echo "No NVIDIA GPU or driver"'
alias gputop='nsenter --target 1 --mount --uts --ipc --net --pid -- nvidia-smi dmon -s u -d 1 -c 5 2>/dev/null || echo "No NVIDIA GPU"'

# ─── Utility ───
alias cls='clear'
alias ll='ls -lAh --color=auto'
alias la='ls -A --color=auto'
alias lt='ls -lAht --color=auto'
alias grep='grep --color=auto'
alias diff='diff --color=auto'
alias tree='tree -C'
alias h='history | tail -30'
alias path='echo $PATH | tr ":" "\n"'
alias now='date +"%Y-%m-%d %H:%M:%S %Z"'
alias epoch='date +%s'

